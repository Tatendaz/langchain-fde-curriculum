# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — put real secrets there, NEVER in this template.

# --- Ollama (model provider) ---
# Local Ollama (default): install from https://ollama.com, run `ollama serve`,
# then `ollama pull llama3.1`. No API key needed for local.
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=                 # only for Ollama Cloud / remote (sent as a Bearer token)
#
# For Ollama Cloud instead, use:
#   OLLAMA_BASE_URL=https://ollama.com
#   OLLAMA_API_KEY=your-ollama-key

# Phase 0 needs a tool-calling model (e.g. llama3.1, qwen2.5, or gpt-oss:20b on Cloud).
MODEL=llama3.1

# --- LangSmith (tracing / observability) ---
# Create a key at https://smith.langchain.com (Settings -> API Keys).
# With these set, every LangChain run is traced automatically.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=langchain-fde-curriculum
